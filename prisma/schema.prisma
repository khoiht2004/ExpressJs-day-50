generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ConversationType {
  direct
  group

  @@map("conversations_type")
}

model User {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  email           String    @unique(map: "user_email") @db.VarChar(255)
  password        String    @db.VarChar(255)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamp(0)
  createdAt       DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime? @map("updated_at") @db.Timestamp(0)

  participants ConversationParticipant[]
  messages     Message[]
  products     Product[]

  @@map("users")
}

model ConversationParticipant {
  conversationId Int @map("conversation_id") @db.UnsignedInt
  userId         Int @map("user_id") @db.UnsignedInt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_participants_conversation_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_participants_user_id")

  @@id([userId, conversationId])
  @@map("conversation_participants")
}

model Conversation {
  id        Int              @id @default(autoincrement()) @db.UnsignedInt
  createdBy String?          @map("created_by") @db.VarChar(255)
  name      String?          @db.VarChar(255)
  type      ConversationType
  createdAt DateTime?        @map("created_at") @db.Timestamp(0)
  updatedAt DateTime?        @map("updated_at") @db.Timestamp(0)

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model Message {
  id             Int       @id @default(autoincrement()) @db.UnsignedInt
  conversationId Int       @map("conversation_id") @db.UnsignedInt
  senderId       Int?      @map("sender_id") @db.UnsignedInt
  content        String?   @db.VarChar(255)
  createdAt      DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime? @map("updated_at") @db.Timestamp(0)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_messages_conversation_id")
  sender       User?        @relation(fields: [senderId], references: [id])

  @@index([conversationId], map: "fk_messages_conversation_id")
  @@map("messages")
}

model Product {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  userId      Int      @map("user_id") @db.UnsignedInt
  name        String   @db.VarChar(255)
  price       Float    @db.Float
  stock       Int      @default(0)
  description String   @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id])

  @@index([userId], map: "fk_products_user_id")
  @@map("products")
}

model Queue {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  type       String?   @db.VarChar(255)
  payload    String?   @db.Text
  status     String?   @default("pending") @db.VarChar(255)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamp(0)
  isPriority Int?      @default(0) @map("is_priority") @db.UnsignedTinyInt
  info       String?   @db.Text

  @@map("queues")
}

model RefreshToken {
  id        Int       @id @default(autoincrement()) @db.UnsignedInt
  userId    Int?      @map("user_id") @db.UnsignedInt
  token     String?   @db.VarChar(255)
  createdAt DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(0)
  expiresAt DateTime? @map("expires_at") @db.Timestamp(0)

  @@map("refresh_tokens")
}

model RevokedToken {
  id        Int       @id @default(autoincrement()) @db.UnsignedInt
  token     String?   @db.Text
  expiresAt DateTime? @map("expires_at") @db.Timestamp(0)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamp(0)

  @@map("revoked_tokens")
}
