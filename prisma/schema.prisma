generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model conversation_participants {
  conversation_id Int @db.UnsignedInt
  user_id         Int @db.UnsignedInt

  conversation conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_participants_conversation_id")
  user         users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_participants_user_id")

  @@id([user_id, conversation_id])
}

model conversations {
  id         Int                @id @default(autoincrement()) @db.UnsignedInt
  created_by String?            @db.VarChar(255)
  name       String?            @db.VarChar(255)
  type       conversations_type
  created_at DateTime?          @db.Timestamp(0)
  updated_at DateTime?          @db.Timestamp(0)

  messages     messages[]
  participants conversation_participants[]
}

model messages {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  conversation_id Int       @db.UnsignedInt
  sender_id       Int?      @db.UnsignedInt
  content         String?   @db.VarChar(255)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)

  conversations conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_messages_conversation_id")
  sender        users?        @relation(fields: [sender_id], references: [id])

  @@index([conversation_id], map: "fk_messages_conversation_id")
}

model queues {
  id          Int       @id @default(autoincrement()) @db.UnsignedInt
  type        String?   @db.VarChar(255)
  payload     String?   @db.Text
  status      String?   @default("pending") @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @default(now()) @db.Timestamp(0)
  is_priority Int?      @default(0) @db.UnsignedTinyInt
  info        String?   @db.Text
}

model refresh_tokens {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  user_id    Int?      @db.UnsignedInt
  token      String?   @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  expires_at DateTime? @db.Timestamp(0)
}

model revoked_tokens {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  token      String?   @db.Text
  expires_at DateTime? @db.Timestamp(0)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
}

model users {
  id                Int       @id @default(autoincrement()) @db.UnsignedInt
  email             String?   @unique(map: "user_email") @db.VarChar(255)
  password          String?   @db.VarChar(255)
  email_verified_at DateTime? @db.Timestamp(0)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)

  participants conversation_participants[]
  messages     messages[]
}

enum conversations_type {
  direct
  group
}
